{
  "manifest_version": 3,
  "name": "SafeHit",
  "version": "1.0.0",
  "description": "Enterprise-grade safeguard and mocking tool.",
  "permissions": ["storage"],
  "options_page": "src/options/index.html",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/interceptor.ts"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/bridge.ts"],
      "run_at": "document_start"
    }
  ]
}